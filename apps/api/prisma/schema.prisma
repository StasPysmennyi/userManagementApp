generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  fullName        String
  role            String
  dateOfBirthday  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
